# ---------------------------------------------------------------------------
# Ventora Idea Check — environment variables (ALL server-only, never exposed)
# Copy to .env.local and fill in. Do NOT prefix any of these with NEXT_PUBLIC_.
# ---------------------------------------------------------------------------

# Vercel AI Gateway — text generation (verdict + advanced report).
# Either set a static key here, or run `vercel env pull .env.local` to provision
# VERCEL_OIDC_TOKEN automatically. AI_GATEWAY_API_KEY takes priority if present.
AI_GATEWAY_API_KEY=

# OpenAI — text generation engine (verdict + advanced report). Server-only.
# Used directly by the @ai-sdk/openai provider in lib/ai.ts.
OPENAI_API_KEY=
# Optional model override; defaults to gpt-5.4.
OPENAI_MODEL=gpt-5.4

# Supabase — lead capture + image cache. Service role key is server-only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Higgsfield — product preview image (Soul still-image model). Server-only.
HIGGSFIELD_API_KEY=
HIGGSFIELD_SECRET=

# Resend — nurture email sequence. Server-only.
# RESEND_FROM must use a domain verified in your Resend account.
RESEND_API_KEY=
RESEND_FROM="Ventora <hi@mail.ventora.cc>"
# HMAC key for stateless one-click unsubscribe tokens. Use a long random string.
UNSUBSCRIBE_SECRET=
# Absolute origin used to build unsubscribe + UTM links inside emails
# (e.g. https://ideacheck.ventora.cc). Falls back to the request origin if unset.
NEXT_PUBLIC_SITE_URL=
# Shared secret guarding the forced nurture test trigger (POST /api/nurture/test).
NURTURE_TEST_SECRET=
